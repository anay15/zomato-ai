# LLM Provider Configuration
# Set to 'groq', 'gemini', or 'openai'
LLM_PROVIDER=groq

# Groq API Key (Required if LLM_PROVIDER is groq)
GROQ_API_KEY=your_groq_api_key_here

# Groq model (optional — defaults to llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini API Key (Required if LLM_PROVIDER is gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (Required if LLM_PROVIDER is openai)
OPENAI_API_KEY=your_openai_api_key_here

# Hugging Face Access Token (Optional, for higher rate limits)
HF_TOKEN=your_hugging_face_token_here